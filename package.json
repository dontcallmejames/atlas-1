{
  "name": "atlas-1",
  "version": "0.1.0",
  "private": true,
  "description": "Atlas 1 — an open-source life console (terminal × game HUD).",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @atlas/console dev",
    "build": "pnpm --filter @atlas/console build",
    "tauri": "tauri",
