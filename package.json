    "tauri:build": "tauri build",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@playwright/test": "^1.48.0",
    "typescript": "^5.6.0"
  }
