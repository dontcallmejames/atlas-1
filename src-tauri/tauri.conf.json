{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atlas 1",
  "version": "0.10.0",
  "identifier": "com.atlas1.console",
  "build": {
    "beforeDevCommand": "pnpm --filter @atlas/console dev",
    "beforeBuildCommand": "pnpm --filter @atlas/console build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../apps/console/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Atlas 1",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob:; connect-src 'self' ipc: https://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
